{
    "device": "CPU",
    "env_config": "env_config.json",
    "sampling": {
        "batch_env": 64,
        "rollout_len": 256,
        "reset_each_rollout": true
    },
    "ppo": {
        "gamma": 0.99,
        "gae_lambda": 0.95,
        "bootstrap": true,
        "clip_range": 0.2,
        "lr": 0.0003,
        "value_lr": 0.0003,
        "entropy_coef": 0.02,
        "value_coef": 0.5,
        "max_grad_norm": 0.5,
        "epochs": 4,
        "minibatch_size": 512,
        "amp": false,
        "amp_bf16": true,
        "collision_done": true,
        "log_std_min": -1.5,
        "log_std_max": 2.0
    },
    "model": {
        "num_queries": 4,
        "num_heads": 4
    },
    "run": {
        "total_env_steps": 5000000,
        "ckpt_dir": "runs/ppo_exp1/",
        "log_interval": 10000
    }
}